# Shared local development values. Copy to .env and fill Cognito values.
AWS_REGION=us-east-1

# PostgreSQL local default used by docker-compose.
POSTGRES_DB=easy_crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_dev_password
DATABASE_URL=postgres://crm:crm_dev_password@postgres:5432/easy_crm

# Backend
PORT=4000
CORS_ORIGIN=http://localhost:5173
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_CLIENT_ID=replace_with_user_pool_client_id
AUTH_DISABLED=false

# Frontend Vite runtime defaults for local dev.
VITE_API_BASE_URL=http://localhost:4000
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_example
VITE_COGNITO_CLIENT_ID=replace_with_user_pool_client_id
VITE_COGNITO_DOMAIN=replace-prefix.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/

# MCP
MCP_TRANSPORT=http
MCP_PORT=4111
MCP_SERVICE_TOKEN=replace_with_local_service_token
COGNITO_CLIENT_IDS=replace_with_user_pool_client_id,replace_with_mcp_confidential_client_id
